{
  "name": "stock-metrics",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "test": "vitest run",
    "test:api": "vitest run tests/integration",
    "test:integration": "vitest run tests/integration",
    "test:component": "vitest run tests/components",
    "test:contract": "vitest run tests/contracts",
    "test:e2e": "playwright test",
    "test:e2e:a11y": "playwright test e2e/accessibility.spec.ts",
    "test:e2e:visual": "playwright test e2e/visual-regression.spec.ts",
    "test:e2e:matrix": "playwright test --config=playwright.matrix.config.ts",
    "test:e2e:matrix:install": "playwright install chromium firefox webkit",
    "test:e2e:headed": "playwright test --headed",
    "test:e2e:ui": "playwright test --ui",
    "load:api": "mkdir -p test-results/load && artillery run tests/load/api-load.yml --output test-results/load/artillery-report.json",
    "test:load": "start-server-and-test \"npm run dev -- --port 3200\" http://127.0.0.1:3200 \"npm run load:api\"",
    "test:security:deps": "npm audit --audit-level=high --omit=dev",
    "test:security:sast": "eslint src --ext .ts,.tsx --max-warnings=0",
    "test:security:secrets": "secretlint \"**/*\" --secretlintrc .secretlintrc.json --secretlintignore .secretlintignore --maskSecrets",
    "test:security": "npm run test:security:deps && npm run test:security:sast && npm run test:security:secrets",
    "test:extended": "npm test && npm run test:contract && npm run test:e2e && npm run test:e2e:matrix && npm run test:load && npm run test:security",
    "test:watch": "vitest",
    "e2e:install": "playwright install chromium",
    "format": "prettier --write .",
    "build:cloudflare": "next build && npx @cloudflare/next-on-pages@1"
  },
  "dependencies": {
    "@tanstack/react-query": "^5.17.19",
    "@tanstack/react-query-devtools": "^5.17.19",
    "@tanstack/react-virtual": "^3.0.0",
    "clsx": "^2.1.0",
    "date-fns": "^2.30.0",
    "fast-xml-parser": "^4.3.4",
    "firebase": "^10.14.1",
    "framer-motion": "^10.16.16",
    "idb": "^8.0.0",
    "jspdf": "^4.2.1",
    "lucide-react": "^0.320.0",
    "next": "13.5.6",
    "nodemailer": "^8.0.4",
    "react": "18.2.0",
    "react-dom": "18.2.0",
    "recharts": "^2.10.4",
    "tailwind-merge": "^2.2.1",
    "xlsx": "^0.18.5",
    "zustand": "^4.5.0"
  },
  "overrides": {
    "cheerio": "1.0.0-rc.12"
  },
  "devDependencies": {
    "@axe-core/playwright": "^4.11.3",
    "@playwright/test": "^1.41.2",
    "@secretlint/secretlint-rule-preset-recommend": "^8.3.0",
    "@testing-library/dom": "^9.3.4",
    "@testing-library/jest-dom": "^6.4.8",
    "@testing-library/react": "^14.3.1",
    "@testing-library/user-event": "^14.5.2",
    "@types/node": "^20.11.17",
    "@types/nodemailer": "^8.0.0",
    "@types/react": "^18.2.48",
    "@types/react-dom": "^18.2.18",
    "artillery": "^1.7.9",
    "autoprefixer": "^10.4.17",
    "eslint": "^8.56.0",
    "eslint-config-next": "13.5.6",
    "eslint-plugin-security": "^1.7.1",
    "jsdom": "^22.1.0",
    "postcss": "^8.4.35",
    "prettier": "^3.2.5",
    "secretlint": "^8.3.0",
    "start-server-and-test": "^2.1.2",
    "tailwindcss": "^3.4.1",
    "typescript": "^5.3.3",
    "vitest": "^0.34.6"
  }
}
